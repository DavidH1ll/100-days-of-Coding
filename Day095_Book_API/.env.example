# Book Collection REST API (Day 95) — environment variables
# Copy this file to .env and fill in real values.
# Never commit .env to source control.

# Flask session signing key.
# Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-api-key

# API key clients must send in the `X-API-Key` header to access the
# /api/* routes. Use any long random string in production.
API_KEY=book-api-secret-2024
