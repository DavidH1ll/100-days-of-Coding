# Pixela Habit Tracker (Day 37) — environment variables
# Copy this file to .env and fill in real values.
# Never commit .env to source control.

# Your Pixela username (set when you run `pixela_tracker.py create-user`).
PIXELA_USERNAME=

# Your Pixela token (the secret you chose at user creation).
# Store this in a password manager. Anyone with this token can post pixels for you.
PIXELA_TOKEN=

# The graph ID you create with `create-graph` (e.g. cycling, reading, study).
PIXELA_GRAPH_ID=
