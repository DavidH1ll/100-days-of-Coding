# Amazon Price Tracker (Day 47) — environment variables
# Copy this file to .env and fill in real values.
# Never commit .env to source control.

# Gmail address that sends the price-alert email.
SENDER_EMAIL=your_email@gmail.com

# Gmail App Password (NOT your normal Gmail password).
# Generate one at https://myaccount.google.com/apppasswords
SENDER_PASSWORD=your_app_password

# Where the price alert gets sent. Can be the same as SENDER_EMAIL.
RECIPIENT_EMAIL=your_email@gmail.com
