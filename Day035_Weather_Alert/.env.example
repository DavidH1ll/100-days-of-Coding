# Day 35 - Weather Alert App
# Rename this file to .env and fill in your values

# OpenWeatherMap API
WEATHER_API_KEY=your_api_key_here
LAT=51.5072
LNG=0.1276
UNITS=metric

# Email (optional, for notifications)
EMAIL_USER=
EMAIL_PASS=
TO_EMAIL=               # defaults to EMAIL_USER if empty
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
USE_TLS=true
FROM_NAME=Weather Alert

# Behavior
DRY_RUN=true
FORCE_ALERT=false
CHECK_INTERVAL=1800     # seconds (30 minutes)
ALERT_HORIZON_HOURS=12  # how far ahead to check in forecast
